# Database
DATABASE_URL=mysql+pymysql://pneumonia_user:Pneumo12345@localhost:3306/pneumonia_db

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=pneumonia_db
MYSQL_USER=pneumonia_user
MYSQL_PASSWORD=Pneumo12345
